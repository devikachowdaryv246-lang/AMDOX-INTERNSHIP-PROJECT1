from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import LSTM, Dense, Dropout

# Prepare data for LSTM
scaler = MinMaxScaler(feature_range=(0, 1))
scaled_data = scaler.fit_transform(data.values.reshape(-1, 1))

# Create sequences (using last 10 days to predict the next day)
X, y = [], []
window_size = 10
for i in range(window_size, len(scaled_data)):
    X.append(scaled_data[i-window_size:i, 0])
    y.append(scaled_data[i, 0])

X, y = np.array(X), np.array(y)
X = np.reshape(X, (X.shape[0], X.shape[1], 1))

# Build LSTM Model
model_lstm = Sequential([
    LSTM(units=50, return_sequences=True, input_shape=(X.shape[1], 1)),
    Dropout(0.2),
    LSTM(units=50),
    Dropout(0.2),
    Dense(units=1)
])

model_lstm.compile(optimizer='adam', loss='mean_squared_error')
model_lstm.fit(X, y, epochs=25, batch_size=32, verbose=0)

# Forecast the next day
last_window = scaled_data[-window_size:].reshape(1, window_size, 1)
prediction_scaled = model_lstm.predict(last_window)
prediction = scaler.inverse_transform(prediction_scaled)

print(f"LSTM Prediction for tomorrow: ${prediction[0][0]:.2f}")
