import requests
from bs4 import BeautifulSoup
from vaderSentiment.vaderSentiment import SentimentIntensityAnalyzer

def get_market_sentiment(crypto_name="bitcoin"):
    # Scrape news headlines from Google News (or similar)
    url = f"https://www.google.com/search?q={crypto_name}+crypto+news&tbm=nws"
    headers = {'User-Agent': 'Mozilla/5.0'}
    
    response = requests.get(url, headers=headers)
    soup = BeautifulSoup(response.text, 'html.parser')
    
    # Extract news titles
    headlines = [h.get_text() for h in soup.find_all('div', dict(role="heading"))]
    
    # Initialize VADER
    analyzer = SentimentIntensityAnalyzer()
    
    results = []
    for text in headlines:
        score = analyzer.polarity_scores(text)
        results.append({
            'headline': text,
            'score': score['compound'] # Compound score is between -1 (Negative) and +1 (Positive)
        })
    
    # Calculate Average Sentiment
    avg_score = sum(item['score'] for item in results) / len(results) if results else 0
    
    return avg_score, results

# Usage
sentiment_score, news_details = get_market_sentiment("bitcoin")
print(f"Overall Market Mood: {sentiment_score}")
